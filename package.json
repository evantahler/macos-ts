{
  "name": "macos-ts",
  "version": "0.10.0",
  "description": "TypeScript package for reading and searching Apple Notes, iMessages, Contacts, and more on macOS via direct SQLite access. Includes markdown conversion, attachment support, and offers a local MCP server!",
  "module": "src/index.ts",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "bin": {
    "macos-mcp": "src/mcp-server.ts"
  },
  "type": "module",
  "license": "MIT",
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/evantahler/macos-ts.git"
  },
  "keywords": [
    "macos",
    "apple-notes",
    "photos",
    "imessage",
    "contacts",
    "addressbook",
    "sqlite",
    "typescript",
    "mcp"
  ],
  "author": "Evan Tahler",
  "scripts": {
    "test": "bun test",
    "lint": "tsc --noEmit && biome check .",
    "format": "biome check --write .",
    "tui": "bun run tui.ts",
    "mcp": "bun run src/mcp-server.ts",
    "create-fixture": "bun run tests/fixtures/create-test-db.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "protobufjs": "^8.0.1"
  }
}
